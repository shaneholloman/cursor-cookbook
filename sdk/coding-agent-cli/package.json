{
  "name": "coding-agent-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.9.0",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "code-agent": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
